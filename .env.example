# ============================================================
# Echo AI Backend — 环境变量模板
# ============================================================
# 本地开发：复制此文件为 .env 并填入真实值
# 服务器部署（Vercel）：在 Vercel Dashboard > Settings >
#   Environment Variables 中逐项添加，不要上传 .env 文件
# ============================================================

# ── 数据库 ──────────────────────────────────────────────────
# 本地开发（如本机 PostgreSQL）：
# POSTGRES_SERVER=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password
# POSTGRES_DB=echo_db

# 服务器/Vercel 必填：使用云数据库完整连接串（推荐 Neon / Supabase）
# Neon 示例：postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/echo_db?sslmode=require
# Supabase 示例：postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# ── JWT 安全 ──────────────────────────────────────────────
# 必须设置为足够长的随机字符串（>=32位），不要使用默认值
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_THIS_WITH_A_SECURE_SECRET_KEY

# ── AI 服务（TokenHub / GLM）────────────────────────────────
TOKENHUB_CHAT_COMPLETIONS_URL=https://tokenhub.tencentmaas.com/v1/chat/completions
# 以下两种鉴权方式二选一：
# 方式 A：直接传入完整 Authorization header 值（含 Bearer 前缀）
TOKENHUB_AUTHORIZATION=Bearer sk-your-api-key-here
# 方式 B：只填 API Key，代码自动加 Bearer 前缀
# TOKENHUB_API_KEY=sk-your-api-key-here

TOKENHUB_MODEL=glm-5
TOKENHUB_CHAT_CONTEXT_LIMIT=20
TOKENHUB_TEMPERATURE=0.7
TOKENHUB_SUMMARY_TEMPERATURE=0.3
# AI 单次请求最大等待时间（秒），glm-5 建议 90
TOKENHUB_TIMEOUT_SECONDS=90

# ── CORS（可选）───────────────────────────────────────────
# 前后端同域部署（Vercel）时可不填
# 如有独立前端域名则填入，多个用逗号分隔：
# BACKEND_CORS_ORIGINS=["https://your-app.vercel.app","https://yourdomain.com"]
BACKEND_CORS_ORIGINS=[]
